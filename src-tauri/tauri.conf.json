{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri/refs/heads/main/crates/tauri-cli/schema.json",
  "productName": "mograder-tauri",
  "version": "0.1.1",
  "identifier": "com.mograder-tauri.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "mograder",
        "width": 1200,
        "height": 800,
        "url": "index.html"
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {},
    "externalBin": ["uv"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
